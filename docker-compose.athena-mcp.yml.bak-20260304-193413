version: '3.8'

services:
  athena-mcp:
    build: ./apps/athena-mcp
    container_name: agent_athena_mcp
    restart: unless-stopped
    ports:
      - "127.0.0.1:8888:8888"
    env_file:
      - ./config/secrets.neo4j.env
    environment:
      # Neo4j is accessible via Docker network (agent_neo4j is on the same network)
      - NEO4J_URI=bolt://agent_neo4j:7687
      - NEO4J_USERNAME=neo4j
      - NEO4J_DATABASE=neo4j
      # Using local sentence-transformer (no API key needed)
      - EMBEDDING_MODEL=all-MiniLM-L6-v2
      # Search configuration
      - DEFAULT_TOP_K=5
      - VECTOR_TOP_K=10
      - FULLTEXT_TOP_K=10
      - RRF_K=60
    networks:
      - agent_net
      - neo4j_default
    volumes:
      - ./apps/athena-mcp:/app:ro
      - ./logs/athena-mcp:/var/log/athena-mcp
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

networks:
  agent_net:
    external: true
  neo4j_default:
    external: true
